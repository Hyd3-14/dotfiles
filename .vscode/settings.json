{
  // ------------------------------------------------------------
  // GitHub Copilot コミットメッセージ生成設定
  // ------------------------------------------------------------
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Language: 必ず日本語で生成してください。"
    },
    {
      "text": "Format: Conventional Commits (<type>(<scope>): <subject>) を使用し、ヘッダー・空行・詳細の3段構成にしてください。"
    },
    {
      "text": "Constraint: Scopeは必ず [ui, page, api, db, auth, config, dev, deps, log] の中から最も適切なものを1つ選んでください。"
    },
    {
      "text": "Detail: なぜその変更を行ったか(Why)を箇条書きで記述してください。変更箇所が自明な場合は簡潔にまとめてください。"
    }
  ],
  "cSpell.words": ["echodo", "toplevel"]
}
